[
  {
    "name": "Modbus-TCP-RTU-test-device",
    "profileName": "Test-Battery-Profile",
    "description": "This device is a product for monitoring and controlling digital inputs and outputs.",
    "labels": [
      "Battery",
      "modbus TCP",
      "modbus RTU"
    ],
    "protocols": {
      "modbus-tcp": {
        "enabled": "true",
        "Address": "0.0.0.0",
        "Port": "5020",
        "UnitID": "1",
        "Endpoint": "tcp://0.0.0.0:5020",
        "Timeout": "5",
        "IdleTimeout": "5"
      },
      "modbus-rtu": {
        "enabled": "false",
        "Address": "/tmp/slave",
        "UnitID": "1",
        "Endpoint": "rtu:///tmp/slave",
        "BaudRate": "19200",
        "DataBits": "8",
        "StopBits": "1",
        "Parity": "N",
        "Timeout": "5",
        "IdleTimeout": "5"
      }
    },
    "autoEvents": [
      {
        "interval": "20s",
        "onChange": false,
        "sourceName": "Battery-Config"
      },
      {
        "interval": "30s",
        "onChange": false,
        "sourceName": "System-Time"
      }
    ]
  }
]